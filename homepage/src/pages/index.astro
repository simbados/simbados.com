---
import Layout from '../layouts/Layout.astro';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Landing Page">
	<div class="background">
		<div class="main">
			<Header title="Index"></Header>
			<div class="container">
				<div class="welcome-screen" id="welcome-id">
					<div id="welcome-message-id" class="message intro-message-active welcome-mobile"></div>
					<div class="arrow-group-left">
						<div class="arrow-down arrow-down-1"></div>
						<div class="arrow-down arrow-down-2"></div>
						<div class="arrow-down arrow-down-3"></div>
					</div>
					<div class="arrow-group-right">
						<div class="arrow-down arrow-down-1"></div>
						<div class="arrow-down arrow-down-2"></div>
						<div class="arrow-down arrow-down-3"></div>
					</div>
				</div>
				<div id="projects" class="project-section">
					<div id="project-message-header" class="project-message project-header"></div>
					<div id="project-message-go" class="project-message mt-05"></div>
					<div id="project-sb" class="project-element" >
						<a rel="noreferrer" href="https://github.com/simbados/sb">Sb</a>
						<div id="sb-desc" class="project-description"></div>
					</div>
					<div id="divider-go" class="divider"></div>
					<div id="project-message-js" class="project-message"></div>
					<div id="project-comparison" class="project-element" >
						<a rel="noreferrer" href="https://github.com/simbados/comparison">Comparison</a>
						<div id="comparison-desc" class="project-description"></div>
					</div>
					<div id="project-website" class="project-element" >
						<a rel="noreferrer" href="https://github.com/simbados/simbados.com">Website</a>
						<div id="website-desc" class="project-description"></div>
					</div>
					<div id="divider-js" class="divider"></div>
					<div id="project-message-others" class="project-message"></div>
					<div id="project-katas" class="project-element" >
						<a rel="noreferrer" href="https://github.com/simbados/katas">Katas</a>
						<a rel="noreferrer" href="https://github.com/simbados/leetcode150">Leetcode</a>
						<div id="katas-desc" class="project-description"></div>
					</div>
				</div>
				<div id="skill-section" class="skill-screen">
					<div class="skill-content">
						<div class="skill-button">Skills</div>
						<div class="skill-node skill-element">Node.js</div>
						<div class="skill-ts skill-element">Typescript</div>
						<div class="skill-vue skill-element">Vue.js</div>
						<div class="skill-nuxt skill-element">Nuxt.js</div>
						<div class="skill-express skill-element">Express.js</div>
						<div class="skill-docker skill-element">Docker</div>
						<div class="skill-angular skill-element">Angular.js</div>
						<div class="skill-java skill-element skill-low">Java</div>
						<div class="skill-go skill-element skill-low">Golang</div>
					</div>
				</div>
				<div id="contact" class="contact-screen">
					<div id="contact-message-id" class="message contact-message-active contact-position"></div>
				</div>
				<Footer></Footer>
			</div>
		</div>
	</div>
</Layout>
<script src="../scripts/main.ts"></script>

<style>
	.background {
		right: 0;
		position: fixed;
		height: 100vh;
		width: 100vw;
		left: 0;
		background: var(--background-color);
		overflow-x: hidden;
		scroll-behavior: smooth;
	}

	.container {
		display: flex;
		flex-direction: column;
		height: calc(100% - var(--navbar-height));
		z-index: 3;
	}

	.container__scrollTop {
		align-self: center;
		color: var(--accent-color);
		cursor: pointer;
		margin: 10px 0 30px 0;
		scroll-behavior: smooth;
	}

	a {
		color: var(--main-color);
		word-break: break-all;
	}

	a:hover {
		color: var(--accent-color);
	}

	.message {
		font-family: 'Courier New', monospace;
		text-align: left;
		white-space: pre-wrap;
		font-size: 1em;
		margin: 0 auto;
		position: absolute;
		left: 15vw;
		top: 30%;
		max-width: 70vw;
	}

	.contact-position {
		left: calc(50vw - 6em);
		top: 40%;
	}

	.welcome-screen {
		font-size: 3em;
		min-height: 100vh;
		width: 100%;
		position: relative;
		z-index: 3;
	}

	.project-section {
		align-items: start;
		font-size: 2.5em;
		display: flex;
		position: relative;
		flex-direction: column;
		justify-content: start;
		min-height: 100vh;
		padding: 0 1em;
		width: 100%;
	}

	.project-message {
		text-align: left;
		white-space: pre-wrap;
		font-size: 1em;
	}

	.project-message-next {
		margin-top: 1em;
	}

	.mt-05 {
		margin-top: 0.5em;
	}

	.message-active::after {
		content: ' ';
		display: inline-block;
		width: 0;
		border-right: 2px solid #000;
		animation: blink 0.8s infinite;
	}

	.project-header {
		font-size: 1.3em;
	}

	.project-element {
		animation: fade-in-1 1s;
		box-sizing: border-box;
		font-size: 0.7em;
		display: none;
		position: relative;
		margin-top: 0.5em;
		height: fit-content;
		width: 100%;

		a {
			background-color: var(--accent-bg-color);
			border: 2px solid var(--accent-color);
			border-radius: 0.3em;
			display: inline-block;
			padding: 0.2em;
			text-decoration: none;
		}

		span {
			word-break: break-word;
			white-space: pre-wrap;
		}
	}

	.project-description {
		margin-top: 0.2em;
		text-align: left;
		white-space: pre-wrap;
	}

	.divider {
		animation: fade-in-1 1s;
		display: none;
		border-top: 1px solid var(--accent-color);
		width: 90vw;
		margin: 0.5em 0;
	}

	.skill-screen,
	.contact-screen {
		min-height: 100vh;
	}

	.skill-content,
	.contact-screen {
		align-items: center;
		font-family: "Arial", sans-serif;
		font-size: 3em;
		display: flex;
		position: relative;
		flex-direction: column;
		justify-content: center;
		height: 100vh;
		width: 100vw;
	}

	.skill-content {
		display: none;
	}


	.skill-button {
		animation: fade-in-1 1s;
		background-color: var(--accent-bg-color);
		border: 3px solid var(--accent-color);
		border-radius: 1.2em;
		padding: 0.5em;
	}

	.skill-low {
		opacity: 0.5;
	}

	.skill-element {
		border: 3px solid var(--accent-color);
		border-radius: 1em;
		font-size: 0.7em;
		padding: 0.8em;
	}

	.skill-node {
		animation: fade-in-2 1s;
		position: absolute;
		left: 10%;
		top: 15%;
	}

	.skill-ts {
		animation: fade-in-2 1.5s;
		position: absolute;
		left: 22%;
		top: 37.5%;
	}

	.skill-vue {
		animation: fade-in-2 2s;
		position: absolute;
		left: 12%;
		top: 62.5%;
	}

	.skill-nuxt {
		animation: fade-in-2 2.5s;
		position: absolute;
		left: 25%;
		top: 82%;
	}

	.skill-express {
		animation: fade-in-2 3s;
		position: absolute;
		left: 47%;
		top: 70%;
	}

	.skill-docker {
		animation: fade-in-2 3.5s;
		position: absolute;
		right: 20%;
		top: 80%;
	}

	.skill-angular {
		animation: fade-in-2 4s;
		position: absolute;
		right: 10%;
		top: 55%;
	}

	.skill-go {
		animation: fade-in-4 4.5s;
		position: absolute;
		right: 45%;
		top: 15%;
	}

	.skill-java {
		animation: fade-in-4 5s;
		position: absolute;
		right: 20%;
		top: 25%;
	}

	@keyframes fade-in-1 {
		0% {
			opacity: 0;
		}

		100% {
			opacity: 1;
		}
	}

	@keyframes fade-in-2 {
		0% {
			opacity: 0;
		}

		50% {
			opacity: 0;
		}

		100% {
			opacity: 1;
		}
	}

	@keyframes fade-in-3 {
		0% {
			opacity: 0;
		}

		75% {
			opacity: 0;
		}

		100% {
			opacity: 1;
		}
	}

	@keyframes fade-in-4 {
		0% {
			opacity: 0;
		}

		50% {
			opacity: 0;
		}

		100% {
			opacity: 0.5;
		}
	}

	.footer {
		align-self: center;
		bottom: 1em;
		display: flex;
		font-size: 12px;
		flex-shrink: 0;
		right: 2em;
		position: fixed;
		justify-self: center;
	}

	.main {
		padding-top: var(--navbar-height);
		position: relative;
		height: fit-content;
	}

	.privacy {
		padding: calc(var(--navbar-height) + 1em) 1em 1em;
	}

	@keyframes arrow-1 {
		0% {
			opacity: 0.2;
		}

		25% {
			opacity: 0.2;
		}

		50% {
			opacity: 0.8;
		}
	}

	@keyframes arrow-2 {
		0% {
			opacity: 0.2;
		}

		50% {
			opacity: 0.2;
		}

		75% {
			opacity: 0.8;
		}
	}

	@keyframes arrow-3 {
		0% {
			opacity: 0.2;
		}

		75% {
			opacity: 0.2;
		}

		100% {
			opacity: 0.8;
		}
	}

	.arrow-down-1 {
		animation: arrow-1 2.5s infinite;
	}

	.arrow-down-2 {
		animation: arrow-2 2.5s infinite;
	}

	.arrow-down-3 {
		animation: arrow-3 2.5s infinite;
	}

	.arrow-group-left {
		position: absolute;
		left: 5%;
		top: 33%;
	}

	.arrow-group-right {
		position: absolute;
		right: 5%;
		top: 33%;
	}

	.arrow-down {
		width: 0;
		height: 0;
		border-left: 20px solid transparent;
		border-right: 20px solid transparent;
		border-top: 20px solid var(--accent-color);
		margin-bottom: 0.5em;
	}

	@keyframes blink {
		0%, 100% {
			border-color: transparent;
		}
		50% {
			border-color: #000;
		}
	}

	@media screen and (max-width: 700px) {
		.arrow-group-left {
			left: 0.4em;
		}

		.arrow-group-right {
			right: 0.4em;
		}

		.message {
			font-size: 0.5em;
		}

		.skill-button {
			font-size: 0.5em;
		}

		.skill-element {
			font-size: 0.4em;
		}

		.arrow-down {
			--base-size: 0.5em;
			width: 0;
			height: 0;
			border-left: var(--base-size) solid transparent;
			border-right: var(--base-size) solid transparent;
			border-top: var(--base-size) solid var(--accent-color);
			margin-bottom: 0.3em;
		}

		.arrow-group-left {
			top: 50%;
			left: 20%;
		}

		.arrow-group-right {
			top: 50%;
			right: 20%;
		}

		.contact-position {
			top: 40%;
		}

		.welcome-mobile {
			top: 15%;
			font-size: 0.55em;
		}

		.skill-node {
			position: absolute;
			left: 10%;
			top: 15%;
		}

		.skill-ts {
			position: absolute;
			left: 18%;
			top: 30%;
		}

		.skill-vue {
			position: absolute;
			left: 12%;
			top: 58%;
		}

		.skill-nuxt {
			position: absolute;
			left: 25%;
			top: 85%;
		}

		.skill-express {
			position: absolute;
			left: 35%;
			top: 70%;
		}

		.skill-docker {
			position: absolute;
			right: 15%;
			top: 82%;
		}

		.skill-angular {
			position: absolute;
			right: 10%;
			top: 60%;
		}

		.skill-go {
			position: absolute;
			right: 20%;
			top: 20%;
		}

		.skill-java {
			position: absolute;
			right: 16%;
			top: 33%;
		}

		.project-section {
			padding: 0 0.5em;
		}

		.project-message {
			font-size: 0.6em;
		}

		.project-element {
			font-size: 0.5em;
		}

		.project-header {
			font-size: 0.7em;
		}
	}
</style>
